    {
      "id": "s01",
      "en": "This is a red apple.",
      "cn": "这是一个红苹果。"
    },
    {
      "id": "s02",
      "en": "I like yellow bananas.",
      "cn": "我喜欢黄色的香蕉。"
    },
    {
      "id": "s03",
      "en": "The orange is big.",
      "cn": "这个橙子好大。"
    },
    {
      "id": "s04",
      "en": "Grapes are small and sweet.",
      "cn": "葡萄又小又甜。"
    },
    {
      "id": "s05",
      "en": "The watermelon is green.",
      "cn": "西瓜是绿色的。"
    },
    {
      "id": "s06",
      "en": "The cat is small.",
      "cn": "猫咪很小。"
    },
    {
      "id": "s07",
      "en": "The bird can fly.",
      "cn": "小鸟会飞。"
    },
    {
      "id": "s08",
      "en": "The rabbit and duck are friends.",
      "cn": "兔子和鸭子是好朋友。"
    },
    {
      "id": "s09",
      "en": "The bear and monkey play together.",
      "cn": "熊和猴子一起玩。"
    },
    {
      "id": "s10",
      "en": "The elephant is big, the lion is brave.",
      "cn": "大象很大，狮子很勇敢。"
    },
    {
      "id": "s11",
      "en": "The sky is blue, the cloud is white.",
      "cn": "天空是蓝色的，云是白色的。"
    },
    {
      "id": "s12",
      "en": "I like pink and black.",
      "cn": "我喜欢粉色和黑色。"
    },
    {
      "id": "s13",
      "en": "Purple and brown are pretty colors.",
      "cn": "紫色和棕色很好看。"
    },
    {
      "id": "s14",
      "en": "The sun and stars are bright.",
      "cn": "太阳和星星很明亮。"
    },
    {
      "id": "s15",
      "en": "The moon and rainbow are beautiful.",
      "cn": "月亮和彩虹很美。"
    },
    {
      "id": "s16",
      "en": "I see with my eyes, I hear with my ears.",
      "cn": "我用眼睛看，用耳朵听。"
    },
    {
      "id": "s17",
      "en": "I smell with my nose, I eat with my mouth.",
      "cn": "我用鼻子闻，用嘴巴吃。"
    },
    {
      "id": "s18",
      "en": "I have two hands and two feet.",
      "cn": "我有两只手和两只脚。"
    },
    {
      "id": "s19",
      "en": "This is my head and face.",
      "cn": "这是我的头和脸。"
    },
    {
      "id": "s20",
      "en": "I wave my arms and kick my legs.",
      "cn": "我挥动手臂，踢动双腿。"
    }
